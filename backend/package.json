{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,ts}\" \"spec/**/*.{js,ts}\" \"eslint.config.cjs\"",
    "format-check": "prettier --check \"src/**/*.{js,ts}\" \"spec/**/*.{js,ts}\" \"eslint.config.cjs\"",
    "test": "jest --runInBand",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "mysql2": "^3.14.1",
    "sqlite3": "^5.1.7",
    "uuid": "^11.1.0",
    "wait-port": "^1.1.0"
  },
  "resolutions": {
    "@babel/core": "7.23.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@babel/core": "^7.26.10",
    "@babel/preset-env": "^7.26.9",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.11",
    "babel-jest": "^29.7.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.8",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "nodemon": "^3.0.3",
    "prettier": "^3.2.4"
  }
}
