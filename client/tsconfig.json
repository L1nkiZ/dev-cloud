{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "jsx": "react-jsx",
        "strict": false,
        "skipLibCheck": true,
        "noEmit": true,
        "esModuleInterop": true,
        "types": ["jest", "node", "@testing-library/jest-dom"]
    },
    "include": ["src", "jest.setup.ts", "vite.config.ts"],
    "exclude": ["dist", "node_modules"]
}
